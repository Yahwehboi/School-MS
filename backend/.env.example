# Copy this to .env and fill in your values
# Never commit the actual .env file to git

# Django
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://schoolms:schoolms@db:5432/schoolms

# CORS (frontend dev server URL)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (use console backend for dev, configure SMTP for prod)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@schoolms.app

# For production SMTP (e.g. SendGrid, Brevo)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key

# Africa's Talking SMS (Phase 4)
# AT_USERNAME=your_username
# AT_API_KEY=your_api_key

# Paystack (Phase 4)
# PAYSTACK_SECRET_KEY=sk_live_xxxx
# PAYSTACK_PUBLIC_KEY=pk_live_xxxx
